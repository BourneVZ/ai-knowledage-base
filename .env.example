# ─────────────────────────────────────────────────────────────
# AI 知识库 · 环境变量配置模板
# ─────────────────────────────────────────────────────────────
# 复制此文件为 .env，填入真实值后即可使用。
# .env 已加入 .gitignore，不会被提交到仓库。
# ─────────────────────────────────────────────────────────────

# ---------- 模型提供商 ----------
# 可选值: deepseek | qwen | openai
LLM_PROVIDER=deepseek

# ---------- 通用 API Key（fallback） ----------
# 优先级低于各提供商的专属 Key，可用于单 Provider 场景
LLM_API_KEY=sk-your-key-here

# ---------- 提供商专属 API Key ----------
DEEPSEEK_API_KEY=sk-your-deepseek-key
QWEN_API_KEY=sk-your-qwen-key
OPENAI_API_KEY=sk-your-openai-key

# ---------- 自定义端点（可选，覆盖默认值） ----------
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- 默认模型（可选） ----------
# DEEPSEEK_DEFAULT_MODEL=deepseek-chat
# QWEN_DEFAULT_MODEL=qwen-plus
# OPENAI_DEFAULT_MODEL=gpt-4o

# ---------- 请求配置 ----------
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=3

# ---------- 自定义定价（可选，$/1K tokens） ----------
# 格式: deepseek_input_price=0.00014
# DEEPSEEK_INPUT_PRICE=0.00014
# DEEPSEEK_OUTPUT_PRICE=0.00028
# QWEN_INPUT_PRICE=0.00050
# QWEN_OUTPUT_PRICE=0.00200
# OPENAI_INPUT_PRICE=0.00250
# OPENAI_OUTPUT_PRICE=0.01000
